# Prisma / DB
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DBNAME"

# HTTP
PORT=3000
NODE_ENV=development

# Auth
JWT_ACCESS_SECRET="change-me"
JWT_REFRESH_SECRET="change-me"
# (fallback legacy)
# JWT_SECRET="change-me"

# QR verification
SIGNATURE_SECRET="change-me"
QR_BASE_URL="http://localhost:5173"

# PDF company info (optional)
COMPANY_ADRESSE=""
COMPANY_TELEPHONE=""
COMPANY_EMAIL=""
COMPANY_BP=""
COMPANY_REGIME=""

# DAF control labels (optional)
# Used in the Demande PDF template for the 4th DAF criterion
DAF_CRITERE4_LABEL="Critère 4"

# Mail (optional)
MAIL_HOST=""
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=""
MAIL_PASS=""
# Disable email sending (useful in dev/test to avoid SMTP timeouts)
MAIL_DISABLED=false
MAIL_FROM_EMAIL=""
MAIL_FROM_NAME=""
MAIL_TEST_TO=""

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

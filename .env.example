# Prisma / DB
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DBNAME"

# Archives V1 (optionnel)
# Si la base V1 est sur le meme serveur MySQL que DATABASE_URL, renseigner seulement le nom de base.
V1_ARCHIVE_DB="devgp_gp"
# Si la base V1 est sur un autre serveur, cette URL prend le dessus sur V1_ARCHIVE_DB.
V1_ARCHIVE_DATABASE_URL="mysql://root:P@sswordAdmin2024@51.75.95.225:3306/devgp_gp"

# HTTP
HOST=0.0.0.0
PORT=3000
NODE_ENV=development

# Auth
JWT_ACCESS_SECRET="change-me"
JWT_REFRESH_SECRET="change-me"
# Fallback legacy
# JWT_SECRET="change-me"

# QR verification
SIGNATURE_SECRET="change-me"
QR_BASE_URL="http://localhost:5173"
FRONTEND_URL="http://localhost:5173"

# PDF company info (optional)
COMPANY_LOGO_URL=""
COMPANY_ADRESSE=""
COMPANY_TELEPHONE=""
COMPANY_EMAIL=""
COMPANY_BP=""
COMPANY_REGIME=""

# DAF control labels (optional)
# Used in the Demande PDF template for the 4th DAF criterion
DAF_CRITERE4_LABEL="Critere 4"

# Mail (optional)
MAIL_HOST=""
MAIL_PORT=587
MAIL_SECURE=false
MAIL_REQUIRE_TLS=true
MAIL_USER=""
MAIL_PASS=""
# Disable email sending (useful in dev/test to avoid SMTP timeouts)
MAIL_DISABLED=false
MAIL_FROM_EMAIL=""
MAIL_FROM_NAME=""
MAIL_TEST_TO=""

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Firma (signature electronique) - optionnel
FIRMA_API_KEY=""
# Endpoint custom (sinon, API par defaut)
FIRMA_API_BASE=""

# Webhooks Firma (optionnel)
FIRMA_WEBHOOK_SECRET=""
# En dev: 1 pour ignorer la verification de signature, 0 pour l'activer
FIRMA_WEBHOOK_SKIP_VERIFY=1
# Appliquer les updates de statut en DB
FIRMA_WEBHOOK_APPLY=1
# Tolerance timestamp (sec) pour la signature webhook
FIRMA_WEBHOOK_TOLERANCE_SEC=300
# Historique d'events en memoire (debug)
FIRMA_WEBHOOK_MAX_EVENTS=100

# Polling "signature terminee" (ms/essais) si l'API tarde
FIRMA_COMPLETE_POLL_ATTEMPTS=10
FIRMA_COMPLETE_POLL_DELAY_MS=800

# Debug (logs API)
FIRMA_DEBUG=0
